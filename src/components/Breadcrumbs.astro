<ul
  id="breadcrumbs-container"
  class="breadcrumbs-container flex text-xl [&_a]:underline"
>
</ul>
<style scoped>
  .breadcrumbs-container {
    li:not(:first-child)::before {
      content: "/";
      margin: 0 0.25rem;
    }
    a {
      text-transform: capitalize;
    }
  }
</style>

<script defer is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    const container = document.querySelector("#breadcrumbs-container");
    const df = document.createDocumentFragment();
    const content = globalThis.location.pathname
      .split("/")
      .reduce(
        (acc, el, idx, arr) =>
          acc +
          `<li><a href=${arr.slice(0, idx).join("/")}/${el}>${el === "" ? "Home" : el}</a></li>`,
        "",
      );
    container.innerHTML = content;
  });
</script>
